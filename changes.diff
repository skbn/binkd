+-  inbound    <path>              Inbound directory (required)
+-  filebox    <path>              Filebox destination (required)
+-  pubdir     <path>              Public directory for --copy-public
+-  logfile    <path>              Log file path
+-  ticlog     <path>              TIC processing log
+-  filelist   <path>              File list output
+-  newfiles   <path>              New files list output
+-
