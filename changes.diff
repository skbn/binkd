++void sess_free(int idx)
++{
++    sess_t *s = &sessions[idx];
++
++    if (s->fd != INVALID_SOCKET)
++    {
++        soclose(s->fd);
++        s->fd = INVALID_SOCKET;
++    }
++
++    if (s->ai_head)
++    {
++        freeaddrinfo(s->ai_head);
++        s->ai_head = NULL;
++    }
++
++    memset(&s->state, 0, sizeof(STATE));
++    s->phase = SESS_FREE;
++}
