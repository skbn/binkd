++/* Helper: scan a single directory for .bsy/.csy files and delete them */
++static void scan_and_delete_bsy_in_dir(const char *dir, BINKD_CONFIG *config)
++{
++    DIR *dp;
++    struct dirent *de;
++    char buf[MAXPATHLEN + 1];
++
++    if ((dp = opendir(dir)) == 0)
++    {
++        return;
++    }
++
++    while ((de = readdir(dp)) != 0)
++    {
++        char *s = de->d_name;
