+-  # process_tic.conf - Configuration for TIC processor
+-
+-  inbound    Work:Inbound
+-  filebox    Work:Filebox
+-  pubdir     Work:Public
+-  logfile    Work:Logs/process_tic.log
+-  ticlog     Work:Logs/tic.log
+-  filelist   Work:Filebox/filelist.txt
