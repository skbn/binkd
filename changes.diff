+-
+-    if (!listpath || !listpath[0])
+-        return;
+-
+-    f = fopen(listpath, "a");
+-    if (!f)
+-        return;
+-
+-    t = time(NULL);
+-    safe_localtime(&t, &tm);
+-    strftime(timestamp, sizeof(timestamp), "%Y-%m-%d %H:%M:%S", &tm);
+-
+-    fprintf(f, "%s\t%s\t%ld\t%s\n", timestamp, file_name, filesize, dst_path);
