++/* Session table */
++int sess_alloc(void)
++{
++    int i;
++
++    for (i = 0; i < max_sessions; i++)
++    {
++        if (sessions[i].phase == SESS_FREE)
++        {
++            memset(&sessions[i], 0, sizeof(sess_t));
++            sessions[i].fd = INVALID_SOCKET;
++            sessions[i].phase = SESS_FREE;
++            return i;
++        }
++    }
++
++    return -1;
++}
