+-
+-/* Linker-compatibility global. Never used at runtime */
+-struct Library *SocketBase = NULL;
+-
+-/* Suppress conflicting C prototypes from clib/bsdsocket_protos.h */
+-#ifndef CLIB_BSDSOCKET_PROTOS_H
