+-static int my_toupper(int c)
+-{
+-    if (c >= 'a' && c <= 'z')
+-        return c - 'a' + 'A';
+-
+-    return c;
+-}
+-
+-static int my_strnicmp(const char *a, const char *b, int n)
+-{
+-    int i, ca, cb;
+-    for (i = 0; i < n; i++)
+-    {
+-        ca = my_toupper((unsigned char)a[i]);
+-        cb = my_toupper((unsigned char)b[i]);
+-
+-        if (ca != cb)
+-            return ca - cb;
+-
+-        if (ca == 0)
+-            return 0;
+-    }
+-
+-    return 0;
+-}
