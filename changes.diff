+-static int parse_file_field(char *line, char *out, int outsize)
+-{
+-    char *p;
+-    char *end;
+-    int len;
+-
+-    p = skip_ws(line);
+-
+-    if (my_strnicmp(p, "File", 4) != 0)
+-        return 0;
+-
+-    p += 4;
+-
+-    if (*p != ' ' && *p != '\t')
+-        return 0;
+-
+-    p = skip_ws(p);
+-    trim_nl(p);
+-    end = p;
+-
+-    while (*end && *end != ' ' && *end != '\t')
+-        end++;
+-
+-    *end = '\0';
+-
+-    len = (int)strlen(p);
+-
+-    if (len <= 0 || len >= outsize)
+-        return 0;
+-
+-    strncpy(out, p, outsize - 1);
+-    out[outsize - 1] = '\0';
+-
+-    return 1;
+-}
