diff -ruN '--exclude=.*' '--exclude=.git' '--exclude=.svn' binkd_pgul/amiga/rename.c binkd/amiga/rename.c
--- binkd_pgul/amiga/rename.c	2026-04-16 17:49:00.000000000 +0100
+++ binkd/amiga/rename.c	2026-04-25 19:33:26.785601976 +0100
@@ -1,10 +1,137 @@
 #include <dos/dos.h>
 #include <proto/dos.h>
+#include <errno.h>
+
+#include <string.h>
+#include <stdlib.h> /* atoi */
